rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User/Teacher
    match /users/{userId} {
      allow get: if true;
      allow create: if isSignedIn() && request.auth.uid == userId && 
                       incoming().keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
                       incoming().role == 'teacher' &&
                       incoming().uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    // Meetings
    match /meetings/{meetingId} {
      allow read: if true; 
      allow create: if isSignedIn() && 
                       isValidId(meetingId) &&
                       incoming().keys().hasAll(['id', 'title', 'teacherId', 'meetingCode', 'jitsiRoomName', 'status', 'createdAt']) &&
                       incoming().teacherId == request.auth.uid;
      allow update: if isSignedIn() && existing().teacherId == request.auth.uid;
    }

    // JoinRequests
    match /joinRequests/{reqId} {
      allow get: if true; 
      allow list: if true; 
      allow create: if isValidId(reqId);
      allow update: if true; // Teacher and student logic simplified
    }

    // Participants
    match /participants/{partId} {
      allow read, write: if true; 
    }

    // Whiteboards
    match /whiteboards/{wbId} {
      allow read, write: if true; 
    }

  }
}

