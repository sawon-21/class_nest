{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Meeting": {
      "title": "Meeting",
      "description": "A live class session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "batchName": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "meetingCode": { "type": "string" },
        "meetingLink": { "type": "string" },
        "jitsiRoomName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "isWhiteboardActive": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "endedAt": { "type": "string" }
      },
      "required": ["id", "title", "teacherId", "meetingCode", "jitsiRoomName", "status", "createdAt"]
    },
    "JoinRequest": {
      "title": "Join Request",
      "description": "Student request to join a meeting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "meetingId": { "type": "string" },
        "meetingCode": { "type": "string" },
        "studentName": { "type": "string" },
        "studentContact": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "participantId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "meetingId", "meetingCode", "studentName", "status", "createdAt"]
    },
    "Participant": {
      "title": "Participant",
      "description": "Approved student in a meeting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "meetingId": { "type": "string" },
        "meetingCode": { "type": "string" },
        "studentName": { "type": "string" },
        "studentContact": { "type": "string" },
        "requestId": { "type": "string" },
        "joinedAt": { "type": "string" },
        "leftAt": { "type": "string" },
        "isActive": { "type": "boolean" },
        "approvedByTeacher": { "type": "boolean" }
      },
      "required": ["id", "meetingId", "studentName", "joinedAt", "isActive", "approvedByTeacher"]
    },
    "Whiteboard": {
      "title": "Whiteboard",
      "description": "Whiteboard data for a meeting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "meetingId": { "type": "string" },
        "lines": { "type": "array" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "meetingId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of teachers"
    },
    "/meetings/{meetingId}": {
      "schema": { "$ref": "#/entities/Meeting" },
      "description": "Collection of meetings"
    },
    "/joinRequests/{requestId}": {
      "schema": { "$ref": "#/entities/JoinRequest" },
      "description": "Join requests for meetings"
    },
    "/participants/{participantId}": {
      "schema": { "$ref": "#/entities/Participant" },
      "description": "Approved participants"
    },
    "/whiteboards/{whiteboardId}": {
      "schema": { "$ref": "#/entities/Whiteboard" },
      "description": "Whiteboard data per meeting"
    }
  }
}
